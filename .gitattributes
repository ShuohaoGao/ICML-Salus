* text=auto eol=lf

# Keep scripts and source files in Unix line endings.
*.sh text eol=lf
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ipynb text eol=lf

# Binary files should not be normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.pkl binary
